# 환경 설정
# 개발: development, 테스트: test, 프로덕션: production
NODE_ENV=development

# 앱 URL (선택사항)
# 예: http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# 아래는 향후 Phase에서 추가될 환경변수입니다.

# Phase 2: 데이터베이스
# DATABASE_URL: Supabase pgBouncer 포트 (6543) - 앱 런타임 연결
# DIRECT_URL: Supabase 직접 포트 (5432) - Prisma 마이그레이션용
DATABASE_URL=postgresql://user:password@host:6543/dbname?pgbouncer=true
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Phase 2: 인증
# AUTH_SECRET: openssl rand -base64 32 로 생성
AUTH_SECRET=your-secret-key-here

# Phase 4: 외부 API (예정)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# RESEND_API_KEY=re_...
# SENTRY_DSN=...
